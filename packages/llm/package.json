{
  "name": "@voidwire/llm",
  "version": "0.1.3",
  "description": "LLM tooling CLI - embed server lifecycle and utility subcommands",
  "type": "module",
  "main": "./index.ts",
  "bin": {
    "llm": "./cli.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./cli": "./cli.ts"
  },
  "files": [
    "index.ts",
    "cli.ts",
    "lib/**/*.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
