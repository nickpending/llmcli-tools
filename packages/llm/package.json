  },
  "keywords": [
    "llm",
    "embed",
    "cli",
    "llcli"
  ],
  "author": "nickpending <nickpending@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickpending/llmcli-tools.git",
    "directory": "packages/llm"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@voidwire/llm-core": "^0.5.0"
  },
  "devDependencies": {
    "bun-types": "1.3.5"
  }
}
