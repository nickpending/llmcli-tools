{
  "name": "@voidwire/dojo",
  "version": "0.1.0",
  "description": "Dojo coaching system — state management CLI",
  "private": false,
  "type": "module",
  "bin": {
    "dojo": "./cli.ts"
  },
  "scripts": {
    "typecheck": "bun tsc --noEmit",
    "lint": "biome check ./cli.ts ./index.ts ./lib/",
