    "format:check": "biome format ./cli.ts ./index.ts ./lib/",
    "format": "biome format --write ./cli.ts ./index.ts ./lib/"
  },
  "dependencies": {
    "ts-fsrs": "5.2.3",
    "@iarna/toml": "2.2.5"
  },
  "devDependencies": {
    "bun-types": "1.3.5"
  }
}
